ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

ADMIN_API_KEY=replace-with-a-random-secret

# Produzione: usa la Session pooler string di Supabase.
DATABASE_URL=
DATABASE_SCHEMA=public
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=10
DATABASE_POOL_TIMEOUT_SECONDS=10

# Dashboard admin
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Lista email separate da virgola. Consigliato in produzione.
DASHBOARD_ALLOWED_EMAILS=

# Seed/versioning dei bot. In produzione il runtime persiste le configurazioni su Supabase.
BOT_CONFIG_DIR=bot_configs
DASHBOARD_DIST_DIR=web/dist

WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=replace-with-meta-verify-token

META_APP_SECRET=
META_ENFORCE_SIGNATURE=true

SQLITE_PATH=data/lead_qualifier.sqlite3
LOG_LEVEL=INFO
