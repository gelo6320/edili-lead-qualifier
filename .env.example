# -----------------------------------------------------------------------------
# Lead Qualifier - Environment template
# Copia in `.env` e compila. Tutti i default sono quelli reali del codice
# (lead_qualifier/core/settings.py). Valori vuoti = richiesti in produzione.
# -----------------------------------------------------------------------------

# --- Anthropic ---------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Database ----------------------------------------------------------------
# In produzione: Session pooler URI di Supabase.
# In locale senza Postgres: lascia vuoto per usare SQLITE_PATH.
DATABASE_URL=
DATABASE_SCHEMA=public
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=10
DATABASE_POOL_TIMEOUT_SECONDS=10
SQLITE_PATH=data/lead_qualifier.sqlite3

# --- Supabase (dashboard auth, Vault, RPC admin) -----------------------------
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Lista email separate da virgola. Se valorizzata, solo queste email entrano.
DASHBOARD_ALLOWED_EMAILS=

# --- Dashboard assets --------------------------------------------------------
BOT_CONFIG_DIR=bot_configs
DASHBOARD_DIST_DIR=web/dist
# URL pubblico della dashboard: usato dal callback OAuth Meta.
APP_BASE_URL=

# --- Meta OAuth (dashboard "Collega Facebook") -------------------------------
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v25.0
# Chiave per firmare il parametro state dell'OAuth. Usa random >= 32 byte.
OAUTH_STATE_SECRET=

# --- WhatsApp Cloud API ------------------------------------------------------
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_GRAPH_VERSION=v25.0
# Fallback globale. Preferito: token del system user custodito in Supabase Vault
# tramite flow OAuth in dashboard.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# --- Sicurezza webhook Meta --------------------------------------------------
# In produzione tenere true: valida X-Hub-Signature-256 sui webhook.
META_ENFORCE_SIGNATURE=true

# --- Cloudflare Browser Rendering (crawl sito cliente + knowledge base) ------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_CRAWL_TIMEOUT_SECONDS=90

# --- HTTP & logging ----------------------------------------------------------
HTTP_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
